{
    "testEnvironment": "node",
    "testMatch": [
        "**/__tests__/**/*.test.js",
        "**/?(*.)+(spec|test).js"
    ],
    "collectCoverageFrom": [
        "**/*.js",
        "!**/node_modules/**",
        "!**/coverage/**",
        "!**/dist/**",
        "!**/logs/**"
    ],
    "coverageThreshold": {
        "global": {
            "branches": 70,
            "functions": 70,
            "lines": 70,
            "statements": 70
        }
    },
    "setupFiles": ["<rootDir>/jest.setup.js"]
}